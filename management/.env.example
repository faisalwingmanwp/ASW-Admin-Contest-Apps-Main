# Database
DATABASE_URL="postgresql://<USER>:<PASSWORD>@<HOST>:6543/<DBNAME>?pgbouncer=true"
DIRECT_URL="postgresql://<USER>:<PASSWORD>@<HOST>:5432/<DBNAME>"

# App configuration
ENTRY_UUID="<uuid-for-entry>"
SONG_ENTRY_PRODUCT_ID="<uuid-for-song-entry>"

# Stripe
FAN_CONTEST_PRODUCT_STRIPE_PRICE_ID="price_xxx"
MEMBERSHIP_PRODUCT_STRIPE_PRICE_ID="price_xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
STRIPE_SECRET_KEY="sk_test_xxx"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://<project>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<supabase-anon-key>"

# Posthog analytics
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
NEXT_PUBLIC_POSTHOG_KEY="<posthog-key>"

# Application URLs
NEXT_PUBLIC_SITE_URL="https://<your-site-url>.com"

# Email (Resend)
RESEND_API_KEY="re_xxx"

# Vercel
VERCEL_OIDC_TOKEN="<vercel-oidc-token>"
